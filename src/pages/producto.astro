---
import Logo from "../assets/images/logo-medileo.svg";
import ProductLayout from "../layouts/ProductLayout.astro";

import dashboard from "../assets/images/Dashboard.png";
import analisi from "../assets/images/Analisi.png";
import alertas from "../assets/images/Alertas.png";
import prototipo3d from "../assets/images/Prototipo_3D.png";
import EyebrowBadge from "../components/common/EyebrowBadge.astro";
import { ChevronLeft } from "@lucide/astro";

const plans = [
  {
    name: "Básico",
    price: "22.000",
    period: "mes",
    description: "Para hogares que quieren empezar a entender su consumo eléctrico.",
    highlight: false,
    cta: "Comenzar ahora",
    features: [
      { text: "2 dispositivos MediLEO incluidos",   included: true },
      { text: "Garantía del equipo",                included: true },
      { text: "Acceso a historial de consumo",      included: true },
      { text: "App web + móvil",                    included: true },
      { text: "Soporte",                            included: true },
    ],
  },
  {
    name: "Hogar",
    price: "45.000",
    period: "mes",
    description: "Para familias que quieren control completo y recomendaciones personalizadas.",
    highlight: true,
    cta: "Elegir Hogar",
    features: [
      { text: "4 dispositivos MediLEO incluidos",   included: true },
      { text: "Garantía del equipo",                included: true },
      { text: "Acceso a historial de consumo",      included: true },
      { text: "Alertas de consumo anómalo",         included: true },
      { text: "App web + móvil",                    included: true },
      { text: "Reportes mensuales automáticos",     included: true },
      { text: "Soporte",                            included: true },
    ],
  },
  {
    name: "Premium",
    price: "75.000",
    period: "mes",
    description: "Análisis avanzado, IA y soporte dedicado para el hogar más exigente.",
    highlight: false,
    cta: "Elegir Premium",
    features: [
      { text: "5 dispositivos MediLEO incluidoss",  included: true },
      { text: "Garantía del equipo",                included: true },
      { text: "Acceso a historial de consumo",      included: true },
      { text: "Alertas de consumo anómalo",         included: true },
      { text: "App web + móvil",                    included: true },
      { text: "Reportes mensuales automáticos",     included: true },
      { text: "Recomendaciones de ahorro con IA",   included: true },
      { text: "Soporte prioritario",                included: true },
    ],
  },
];

const screenshots = [
  { label: "Dashboard principal",    src: dashboard, alt: "Dashboard de consumo en tiempo real" },
  { label: "Gráfica por hora y día", src: analisi, alt: "Gráfica de consumo histórico" },
  { label: "Alertas inteligentes",   src: alertas, alt: "Panel de alertas" },
];
---


<ProductLayout>
    <!-- ── HEADER ───────────────────────────────────────────────── -->
    <header class="sticky top-0 z-10 border-b border-gray-200 bg-primary">
      <div class="mx-auto flex min-h-14 max-w-7xl flex-wrap items-center justify-between gap-2 px-4 py-1 sm:px-6 lg:px-8">
        <Logo width={140} class="w-32 sm:w-36 md:w-40" />
        <a href="/#como-funciona" class="inline-flex items-center  gap-2 text-sm font-medium sm:gap-3 sm:text-base lg:gap-4 lg:text-lg text-secondary hover:text-secondary-900 transition-colors">
          <ChevronLeft class="h-4 w-4" aria-hidden="true"/>
          Volver al inicio
        </a>
      </div>
    </header>

    <main>
      <!-- ── HERO ─────────────────────────────────────────────── -->
      <section class="flex min-h-[calc(100dvh-6rem)] w-full items-center px-6 py-10 sm:px-8 lg:px-12 lg:py-12 bg-linear-to-br from-5% from-white to-accent">
        <div class="mx-auto flex w-full max-w-6xl flex-col items-center text-center">
          <EyebrowBadge label="Dispositivo IoT + Plataforma" />
          <h1 class="text-5xl md:text-6xl font-bold text-text leading-tight max-w-4xl mx-auto font-primary">
            El sistema completo, desde el enchufe hasta tu pantalla
          </h1>
          <p class="mt-6 text-secondary-900 max-w-2xl mx-auto text-lg font-secondary">
            Un pequeño dispositivo que se instala en tu medidor eléctrico y
            una plataforma que convierte esos datos en decisiones claras.
            Sin cables extra. Sin técnicos especializados.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a href="#precios"
              class="rounded-xl bg-secondary px-6 py-3 text-sm font-semibold text-primary hover:opacity-90 transition-opacity">
              Ver precios
            </a>
            <a href="#dispositivo"
              class="rounded-xl px-6 py-3 text-sm font-semibold text-text/70 bg-primary/80 hover:text-secondary hover:bg-primary transition-colors duration-200">
              Conocer el dispositivo
            </a>
          </div>
        </div>
      </section>

      <!-- ── DISPOSITIVO ───────────────────────────────────────── -->
      <section id="dispositivo" class="px-6 py-24 bg-surface">
        <div class="max-w-6xl mx-auto">
          <EyebrowBadge label="Hardware · ESP32-S3" />

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Placeholder del dispositivo -->
            <div class="rounded-3xl bg-accent/10 border border-gray-200 flex items-center justify-center min-h-85 overflow-hidden">
              <img
                src={prototipo3d.src}
                alt="Dispositivo MediLEO"
                class="w-full h-full object-cover"
              />
            </div>

            <div>
              <h2 class="text-3xl md:text-4xl font-bold text-text leading-tight font-primary">
                Pequeño en tamaño, grande en datos
              </h2>
              <p class="mt-4 text-secondary-900 leading-relaxed font-secondary">
                El dispositivo MediLEO se conecta de forma no invasiva al medidor
                de tu hogar. Captura corriente, voltaje, temperatura y potencia
                cada pocos segundos, y los envía a la nube vía WiFi sin
                interrumpir el suministro.
              </p>

              <ul class="mt-8 flex flex-col gap-3">
                {[
                  ["Microcontrolador",   "ESP32-S3 N16R8 (WiFi + BT integrado)"],
                  ["Sensor de corriente","SCT-013 (no invasivo, sin cortar cables)"],
                  ["Sensor de temperatura","TMP36 integrado"],
                  ["Métricas medidas",   "Corriente · Voltaje · Potencia · Energía · Temperatura"],
                  ["Actualización",      "Dato nuevo cada 3 segundos"],
                  ["Conectividad",       "WiFi 2.4 GHz — sin instalación compleja"],
                ].map(([label, value]) => (
                  <li class="grid grid-cols-[160px_1fr] gap-2 text-sm border-b border-gray-200 pb-3">
                    <span class="font-medium text-text">{label}</span>
                    <span class="text-secondary-900/70">{value}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- ── INTERFAZ / SCREENSHOTS ────────────────────────────── -->
      <section class="px-6 py-24 bg-[#F9F6EE]">
        <div class="mx-auto flex w-full max-w-6xl flex-col">
          <EyebrowBadge label="Plataforma · Web + Móvil" />
          <h2 class="text-3xl md:text-4xl font-bold text-secondary leading-tight max-w-3xl">
            La interfaz que convierte datos en decisiones
          </h2>
          <p class="mt-4 text-secondary-900 max-w-2xl text-lg">
            Gráficas por hora y por día, alertas automáticas y recomendaciones
            claras — todo en una pantalla que cualquier miembro de la familia
            puede entender.
          </p>

          <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6 items-stretch">
            {screenshots.map((shot) => (
              <div class="flex h-full flex-col overflow-hidden rounded-[22px] border border-gray-200 bg-primary shadow-sm">
                {shot.src ? (
                  <div class="flex h-50 items-center justify-center overflow-hidden bg-accent/5 p-0 sm:h-55 lg:h-62.5">
                    <img
                      src={shot.src.src}
                      alt={shot.alt}
                      class="h-full w-full object-cover object-center"
                    />
                  </div>
                ) : (
                  <div class="flex h-50 items-center justify-center bg-secondary p-8 sm:h-55 lg:h-62.5">
                    <div class="text-center opacity-40">
                      <p class="text-xs font-medium text-text">{shot.alt}</p>
                    </div>
                  </div>
                )}
                <div class="border-t border-gray-200 bg-secondary px-4 py-3 sm:px-5 sm:py-4">
                  <p class="text-sm font-semibold text-primary">{shot.label}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="precios" class="px-6 py-24 bg-surface">
        <div class="max-w-6xl mx-auto">
          <EyebrowBadge label="Planes · Suscripción mensual en COP" />
          <h2 class="text-3xl md:text-4xl font-bold text-text leading-tight max-w-3xl font-primary">
            Elige el plan que se ajusta a tu hogar
          </h2>
          <p class="mt-4 text-secondary-900 max-w-2xl text-lg font-secondary">
            Sin permanencia mínima. Cancela cuando quieras. El dispositivo
            físico se incluye con cualquier plan activo.
          </p>

          <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
            {plans.map((plan) => (
              <div class={`rounded-3xl border p-8 flex flex-col gap-5 relative ${
                plan.highlight
                  ? "border-gray-200 bg-secondary text-primary shadow-xl scale-[1.03]"
                  : "border-gray-200 bg-primary text-text shadow-sm"
              }`}>
                {plan.highlight && (
                  <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                    <span class="rounded-full bg-primary text-secondary text-xs font-bold px-4 py-1 shadow">
                      Más popular
                    </span>
                  </div>
                )}

                <!-- Nombre y descripción -->
                <div>
                  <h3 class={`text-lg font-bold font-primary ${plan.highlight ? "text-primary" : "text-text"}`}>
                    {plan.name}
                  </h3>
                  <p class={`mt-1 text-sm leading-relaxed font-secondary-900 ${plan.highlight ? "text-primary/70" : "text-text/60"}`}>
                    {plan.description}
                  </p>
                </div>

                <!-- Precio -->
                <div class="flex items-end gap-1">
                  <span class={`text-xs font-semibold ${plan.highlight ? "text-primary/60" : "text-text/40"}`}>
                    COP $
                  </span>
                  <span class={`text-4xl font-black leading-none ${plan.highlight ? "text-primary" : "text-text"}`}>
                    {plan.price}
                  </span>
                  <span class={`text-sm mb-1 ${plan.highlight ? "text-primary/60" : "text-text/40"}`}>
                    /{plan.period}
                  </span>
                </div>

                <!-- CTA -->
                <a
                  href="/#contacto"
                  class={`rounded-xl py-3 text-sm font-semibold text-center transition-opacity hover:opacity-90 ${
                    plan.highlight
                      ? "bg-primary text-secondary"
                      : "bg-secondary text-primary"
                  }`}
                >
                  {plan.cta}
                </a>

                <!-- Features -->
                <ul class="flex flex-col gap-2.5 pt-2">
                  {plan.features.map((f) => (
                    <li class={`flex items-start gap-2.5 text-sm font-secondary ${
                      f.included
                        ? plan.highlight ? "text-primary" : "text-text"
                        : plan.highlight ? "text-primary/30" : "text-text/30"
                    }`}>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                        stroke-linejoin="round"
                        class={`h-4 w-4 mt-0.5 shrink-0 ${f.included ? "opacity-100" : "opacity-30"}`}>
                        {f.included
                          ? <polyline points="20 6 9 17 4 12"/>
                          : <line x1="5" y1="12" x2="19" y2="12"/>
                        }
                      </svg>
                      {f.text}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          <p class="mt-8 text-center text-sm text-secondary-900">
            Todos los precios incluyen el hardware. El dispositivo permanece
            activo mientras la suscripción esté vigente.
          </p>
        </div>
      </section>

    </main>

    <!-- ── FOOTER SIMPLE ─────────────────────────────────────────── -->
    <footer class="border-t border-gray-200 px-6 py-8">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text/40">
        <p>&copy; {new Date().getFullYear()} MediLEO. Todos los derechos reservados.</p>
        <a href="/" class="hover:text-accent transition-colors">← Volver al inicio</a>
      </div>
    </footer>
</ProductLayout>