---
import EyebrowBadge from './common/EyebrowBadge.astro';
---

<section class="w-full flex min-h-[calc(100dvh-6rem)] items-center px-6 py-10 sm:px-8 lg:px-12 lg:py-12 bg-linear-to-br from-5% from-white to-accent">
  <div class="mx-auto flex w-full max-w-6xl flex-col">
    <EyebrowBadge label="Solución IoT · Costa Caribe Colombiana" />
    <div class="flex flex-col gap-y-4 sm:gap-y-5">
      <h1 class="max-w-3xl text-4xl font-bold leading-tight text-secondary md:text-5xl lg:text-7xl hero-title font-primary">
        Conoce y controla tu consumo eléctrico en tiempo real.
      </h1>
      <h2 class="max-w-2xl text-lg text-secondary-900 hero-sub font-secondary sm:text-xl">
        Con MediLeo, monitorea tu energía al instante y transforma esos datos en recomendaciones claras para ahorrar energía y dinero.
      </h2>
    </div>
  </div>
</section>

<script>
  import { animate, inView } from 'motion';

  inView('.hero-title', (element) => {
    animate(element, { opacity: [0, 1], y: [60, 0] }, { duration: 0.7, delay: 0.1 });
  });
  inView('.hero-sub', (element) => {
    animate(element, { opacity: [0, 1], y: [30, 0] }, { duration: 0.5, delay: 0.4 });
  });
</script>

