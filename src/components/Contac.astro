---
// Con Netlify Forms: agrega data-netlify="true" al <form> y listo.

const contactInfo = {
  email: "contacto@medileo.com",
  hoursWeekday: "Lun – Vie: 8 am – 6 pm",
  hoursWeekend: "Sáb: 9 am – 1 pm",
  location: "Barranquilla, Colombia",
};
---

<section id="contacto" class="px-6 py-24 max-w-6xl mx-auto">
  <!-- Eyebrow -->
  <div class="inline-flex items-center gap-2 rounded-full border border-quaternary-200 bg-primary px-4 py-1.5 text-sm text-secondary-900/70 mb-6">
    <span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>
    Contacto · Estamos aquí para ayudarte
  </div>

  <h2 class="text-4xl md:text-5xl font-bold text-secondary leading-tight max-w-3xl">
    ¿Tienes preguntas sobre MediLEO?
  </h2>
  <p class="mt-4 text-secondary-900/70 max-w-2xl text-lg">
    Escríbenos. Ya sea para saber más del proyecto, una colaboración o
    simplemente dar feedback — te respondemos a la brevedad.
  </p>

  <div class="mt-12 grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-8 items-start">

    <!-- Formulario -->
    <form
      method="POST"
      action="#"
      class="rounded-3xl border border-quaternary-200 bg-primary p-8 flex flex-col gap-5"
    >
      <!-- Nombre -->
      <div class="flex flex-col gap-1.5">
        <label for="nombre" class="text-sm font-medium text-secondary">
          Nombre
        </label>
        <input
          id="nombre"
          name="nombre"
          type="text"
          placeholder="Tu nombre completo"
          required
          class="rounded-xl border border-quaternary-200 px-4 py-3 text-sm text-secondary placeholder:text-secondary-900/40 outline-none focus:border-secondary focus:ring-2 focus:ring-quaternary-200/60 transition"
        />
      </div>

      <!-- Correo -->
      <div class="flex flex-col gap-1.5">
        <label for="correo" class="text-sm font-medium text-secondary">
          Correo electrónico
        </label>
        <input
          id="correo"
          name="correo"
          type="email"
          placeholder="tu@correo.com"
          required
          class="rounded-xl border border-quaternary-200 px-4 py-3 text-sm text-secondary placeholder:text-secondary-900/40 outline-none focus:border-secondary focus:ring-2 focus:ring-quaternary-200/60 transition"
        />
      </div>

      <!-- Mensaje -->
      <div class="flex flex-col gap-1.5">
        <label for="mensaje" class="text-sm font-medium text-secondary">
          Mensaje
        </label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="5"
          placeholder="Cuéntanos en qué podemos ayudarte..."
          required
          class="rounded-xl border border-quaternary-200 px-4 py-3 text-sm text-secondary placeholder:text-secondary-900/40 outline-none focus:border-secondary focus:ring-2 focus:ring-quaternary-200/60 transition resize-none"
        ></textarea>
      </div>

      <!-- Botón -->
      <button
        type="submit"
        class="mt-1 w-full rounded-xl bg-secondary py-3 text-sm font-semibold text-primary hover:opacity-90 transition-opacity"
      >
        Enviar mensaje
      </button>
    </form>

    <!-- Info de contacto -->
    <div class="flex flex-col gap-4">

      <!-- Email -->
      <div class="rounded-2xl border border-border p-6">
        <div class="flex h-9 w-9 items-center justify-center rounded-full bg-primary/20 text-accent mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" class="h-4 w-4">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </div>
        <p class="text-xs font-semibold uppercase tracking-wide text-secondary-900/50 mb-1">
          Correo
        </p>
        <a
          href={'mailto:${contactInfo.email}'}
          class="text-sm font-medium text-secondary hover:underline break-all"
        >
          {contactInfo.email}
        </a>
      </div>

      <!-- Horarios -->
      <div class="rounded-2xl border border-border p-6">
        <div class="flex h-9 w-9 items-center justify-center rounded-full bg-primary/20 text-accent mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" class="h-4 w-4">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <p class="text-xs font-semibold uppercase tracking-wide text-secondary-900/50 mb-2">
          Horario de atención
        </p>
        <p class="text-sm text-secondary">{contactInfo.hoursWeekday}</p>
        <p class="text-sm text-secondary-900/70">{contactInfo.hoursWeekend}</p>
      </div>

      <!-- Ubicación -->
      <div class="rounded-2xl border border-border p-6">
        <div class="flex h-9 w-9 items-center justify-center rounded-full bg-primary/20 text-accent mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" class="h-4 w-4">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <p class="text-xs font-semibold uppercase tracking-wide text-secondary-900/50 mb-1">
          Ubicación
        </p>
        <p class="text-sm text-secondary">{contactInfo.location}</p>
      </div>

    </div>
  </div>
</section>