---
import EyebrowBadge from "./common/EyebrowBadge.astro";

const team = [
  {
    initials: "JD",
    name: "Juan Diego Rendon",
    role: "---",
    bio: "___ y colaborador en la creacion web y app.",
  },
  {
    initials: "JD",
    name: "Juan David",
    role: "Lider del proyecto",
    bio: "...",
  },
  {
    initials: "LC",
    name: "Luis Castro",
    role: "Developer y diseñador web y app.",
    bio: "---",
  },
  {
    initials: "LD",
    name: "Leonard Díaz",
    role: "---",
    bio: "---",
  },
];
---

<section id="team" class="px-6 py-24">
  <div class="mx-auto flex w-full max-w-5xl flex-col">
    <!-- Eyebrow badge -->
    <EyebrowBadge label="El equipo · Barranquilla, Colombia" />

    <!-- Heading -->
    <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight max-w-3xl font-primary">
      Cuatro personas, un sistema completo
    </h2>
    <p class="mt-4 text-gray-600 max-w-2xl text-lg font-secondary">
      MediLEO nace como proyecto de un equipo pequeño que divide el problema
      igual que se divide el sistema: hardware, datos, plataforma y experiencia
      de usuario.
    </p>

    <!-- Grid de integrantes -->
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        team.map((member) => (
          <div class="rounded-2xl border border-gray-200 p-6">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gray-900 text-white font-semibold mb-4">
              {member.initials}
            </div>
            <h3 class="font-semibold text-gray-900">{member.name}</h3>
            <p class="text-sm text-gray-500 mt-0.5">{member.role}</p>
            <p class="mt-3 text-sm text-gray-600 leading-relaxed">
              {member.bio}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
