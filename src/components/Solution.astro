---
import {
    Cpu,
    ChartColumn,
    Sparkles,
    type Icon as IconType,
} from "@lucide/astro";
import EyebrowBadge from "./common/EyebrowBadge.astro";

type FeatureCard = {
    title: string;
    label: string;
    icon: typeof IconType;
};

const steps = [
    {
        id: "1",
        title: "Captura del medidor",
        label: "El ESP32 se conecta al medidor del hogar y registra el consumo de energía continuamente.",
        tech: "Hardware · C/C++",
    },
    {
        id: "2",
        title: "Envío a la nube vía WiFi",
        label: "Los datos viajan en tiempo real a la plataforma MediLEO sin cables adicionales ni instalaciones complejas.",
        tech: "WiFi · Tiempo real",
    },
    {
        id: "3",
        title: "Visualización y alertas",
        label: "La app web/móvil muestra gráficos por hora y día, detecta gastos anómalos y genera recomendaciones prácticas.",
        tech: "App móvil",
    },
];

const featureCards: FeatureCard[] = [
    {
        title: "Monitor IoT en tiempo real",
        label: "El ESP32 mide continuamente los kWh de la vivienda y los envía a la nube sin interrupciones.",
        icon: Cpu,
    },
    {
        title: "Gráficas y alertas intuitivas",
        label: "Visualiza tu consumo por hora o por día y recibe alertas si detectamos un uso excesivo o inusual.",
        icon: ChartColumn,
    },
    {
        title: "Recomendaciones inteligentes",
        label: "Analizamos tus patrones de uso y te sugerimos acciones concretas: cambio de equipos, hábitos y horarios.",
        icon: Sparkles,
    },
];

const dashboardStats = [
    { label: "Consumo hoy", value: "8.4 kWh", change: "−12% vs. ayer" },
    { label: "Costo estimado", value: "$9.800", change: "COP · al día" },
    { label: "Pico detectado", value: "14:30", change: "AC · 2.1 kWh/h" },
];

const hourlyBars = [35, 42, 28, 55, 72, 88, 95, 78, 65, 48, 40, 52];
---

<section id="solution" class="px-6 py-24">
    <div class="mx-auto flex w-full max-w-5xl flex-col">
        <EyebrowBadge label="La solución · Medición inteligente" />

        <h2 class="text-4xl md:text-5xl font-bold text-secondary leading-tight max-w-3xl font-primary">
            Medición inteligente al alcance de cada hogar
        </h2>
        <p class="mt-4 text-secondary-900 max-w-2xl text-lg font-secondary">
            MediLEO convierte datos de consumo eléctrico en información útil,
            clara y accionable — minuto a minuto, desde un dispositivo IoT
            accesible.
        </p>

        <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="rounded-2xl border border-quaternary-200 p-6">
                <span class="font-medium text-secondary-900/60 mb-5 block text-xs uppercase tracking-wide">
                    Cómo funciona el sistema
                </span>
                <div class="space-y-5">
                    {
                        steps.map((step) => (
                            <div class="flex gap-3 items-start">
                                <div class="flex items-center justify-center w-7 h-7 rounded-full shrink-0 border border-quaternary-200 text-sm font-medium text-secondary-900">
                                    {step.id}
                                </div>
                                <div class="space-y-1">
                                    <h3 class="text-lg font-semibold tracking-tight text-secondary">
                                        {step.title}
                                    </h3>
                                    <p class="text-sm text-secondary-900 leading-relaxed">
                                        {step.label}
                                    </p>
                                    <span class="inline-block border border-quaternary-200 rounded-full px-3 py-1 text-xs text-secondary-900 mt-2">
                                        {step.tech}
                                    </span>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <div class="rounded-2xl border border-quaternary-200 p-6 bg-quaternary-100/60">
                <div class="flex items-center justify-between mb-5">
                    <span class="font-medium text-secondary-900/60 text-xs uppercase tracking-wide">
                        Panel del hogar · Hoy
                    </span>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-primary border border-quaternary-200 px-2.5 py-1 text-xs text-secondary-900">
                        <span class="h-1.5 w-1.5 rounded-full bg-secondary animate-pulse"></span>
                        En vivo
                    </span>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
                    {
                        dashboardStats.map((stat) => (
                            <div class="rounded-xl border border-quaternary-200 bg-primary p-3">
                                <p class="text-xs text-secondary-900/70">
                                    {stat.label}
                                </p>
                                <p class="mt-1 text-lg font-bold text-secondary">
                                    {stat.value}
                                </p>
                                <p class="mt-0.5 text-xs text-secondary-900/60">
                                    {stat.change}
                                </p>
                            </div>
                        ))
                    }
                </div>

                <div class="rounded-xl border border-quaternary-200 bg-primary p-4">
                    <div class="flex items-center justify-between mb-4">
                        <p class="text-sm font-medium text-secondary">
                            Consumo por hora
                        </p>
                        <p class="text-xs text-secondary-900/60">Últimas 12 h</p>
                    </div>
                    <div class="flex items-end justify-between gap-1 h-24" aria-hidden="true">
                        {
                            hourlyBars.map((height) => (
                                <div class="flex-1 rounded-sm bg-tertiary-800/80" style={`height: ${height}%`} />
                            ))
                        }
                    </div>
                </div>

                <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3">
                    <p class="text-sm font-medium text-amber-900">
                        Alerta de consumo
                    </p>
                    <p class="mt-1 text-xs text-amber-800 leading-relaxed">
                        El aire acondicionado superó el promedio diario entre
                        14:00 y 15:00. Considera subir 1°C para ahorrar ~$1.200
                        COP hoy.
                    </p>
                </div>
            </div>
        </div>

        <blockquote class="border-l-4 border-quaternary-200 pl-4 my-10">
            <p class="text-sm leading-7 italic text-secondary-900/70">
                "La medición inteligente permite un mayor empoderamiento del
                consumidor eléctrico, al brindarle datos precisos de su uso
                energético". MediLEO aplica este principio: al conocer y
                entender el propio consumo, los hogares aprenden a ahorrar.
            </p>
        </blockquote>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {
                featureCards.map((card) => (
                    <div class="rounded-2xl border border-quaternary-200 p-6">
                        <div class="flex h-9 w-9 items-center justify-center rounded-full bg-quaternary-100 text-secondary-900">
                            <card.icon class="h-5 w-5" aria-hidden="true" />
                        </div>
                        <div class="mt-4 flex flex-col gap-y-2">
                            <h3 class="text-xl font-semibold text-secondary">
                                {card.title}
                            </h3>
                            <p class="text-sm text-secondary-900 leading-relaxed">
                                {card.label}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
