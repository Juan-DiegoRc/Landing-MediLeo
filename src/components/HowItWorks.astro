---
import {
    MoveRight,
    Cloud,
    Cpu,
    House,
    Smartphone,
    type Icon as IconType,
} from "@lucide/astro";
import EyebrowBadge from "./common/EyebrowBadge.astro";

type FlowNode = {
    kind: "node";
    title: string;
    subtitle: string;
    badge: string;
    icon: typeof IconType;
};

type FlowConnector = {
    kind: "connector";
    label: string;
};

type FlowItem = FlowNode | FlowConnector;

type StepCard = {
    id: string;
    eyebrow: string;
    title: string;
    description: string;
};

const flowItems: FlowItem[] = [
    {
        kind: "node",
        title: "Dispositivo IoT",
        subtitle: "ESP32 · Sensores",
        badge: "Hogar",
        icon: Cpu,
    },
    { kind: "connector", label: "WiFi" },
    {
        kind: "node",
        title: "Servidor en la nube",
        subtitle: "Plataforma MediLEO",
        badge: "Nube",
        icon: Cloud,
    },
    { kind: "connector", label: "API" },
    {
        kind: "node",
        title: "App Móvil",
        subtitle: "Gráficos · alertas",
        badge: "Plataforma",
        icon: Smartphone,
    },
    { kind: "connector", label: "Insights" },
    {
        kind: "node",
        title: "Usuario",
        subtitle: "Hogar",
        badge: "Decisión",
        icon: House,
    },
];

const stepCards: StepCard[] = [
    {
        id: "1",
        eyebrow: "Medición · Hogar",
        title: "Captura en el punto de consumo",
        description:
            "El ESP32 con sensores se conecta al medidor o a un punto clave del hogar y registra el consumo eléctrico en tiempo real.",
    },
    {
        id: "2",
        eyebrow: "Transmisión · Nube",
        title: "Envío continuo por internet",
        description:
            "Cada segundo o minuto, el ESP32 envía los datos por WiFi a la plataforma MediLEO alojada en la nube.",
    },
    {
        id: "3",
        eyebrow: "Procesamiento · Plataforma",
        title: "Análisis e informe dinámico",
        description:
            "El sistema identifica cuántos kWh consumió cada aparato (nevera, AC, luces) y genera un informe dinámico actualizado.",
    },
    {
        id: "4",
        eyebrow: "Visualización · Usuario",
        title: "Decisiones con información clara",
        description:
            "Consultas la app y ves gráficos diarios y mensuales, alertas automáticas y consejos concretos para reducir tu factura.",
    },
];

const techSpecs = [
    {
        label: "Hardware",
        value: "ESP32 · C/C++ · Sensores de corriente",
    },
    {
        label: "Conectividad",
        value: "WiFi · Protocolo MQTT / HTTP",
    },
];
---

<section id="how-it-works" class="px-6 py-24">
    <div class="mx-auto flex w-full max-w-5xl flex-col">
        <EyebrowBadge label="Arquitectura del sistema" />

        <h2 class="text-4xl md:text-5xl font-bold text-secondary leading-tight max-w-3xl font-primary">
            Del medidor a tu pantalla en tiempo real
        </h2>
        <p class="mt-4 text-secondary-900 max-w-2xl text-lg font-secondary">
            MediLEO recorre cuatro etapas automáticas — desde que el sensor
            captura la energía hasta que tú ves el dato en tu app y tomas una
            decisión.
        </p>

        <div class="mt-12 w-full rounded-2xl border border-quaternary-200 p-6 md:p-8 overflow-x-auto">
            <div class="flex min-w-max md:min-w-0 items-center justify-between gap-2 md:gap-0">
                {
                    flowItems.map((item) =>
                        item.kind === "node" ? (
                            <div class="flex flex-col items-center justify-center gap-y-2 px-2">
                                <span class="flex h-14 w-14 items-center justify-center rounded-xl border border-quaternary-200 bg-quaternary-100 text-secondary-900">
                                    <item.icon
                                        class="h-5 w-5"
                                        aria-hidden="true"
                                    />
                                </span>
                                <h3 class="text-sm font-semibold text-secondary text-center">
                                    {item.title}
                                </h3>
                                <span class="text-xs text-secondary-900/70 text-center">
                                    {item.subtitle}
                                </span>
                                <span class="inline-flex items-center rounded-full border border-quaternary-200 px-2.5 py-0.5 text-xs text-secondary-900">
                                    {item.badge}
                                </span>
                            </div>
                        ) : (
                            <div class="flex flex-col items-center gap-y-1 px-1 shrink-0">
                                <MoveRight
                                    class="h-4 w-4 text-secondary-900/50"
                                    aria-hidden="true"
                                />
                                <span class="text-xs text-secondary-900/50">
                                    {item.label}
                                </span>
                            </div>
                        ),
                    )
                }
            </div>
        </div>

        <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {
                stepCards.map((step) => (
                    <div class="rounded-2xl border border-quaternary-200 p-6">
                        <div class="flex h-7 w-7 items-center justify-center rounded-full border border-quaternary-200 text-sm font-medium text-secondary-900">
                            {step.id}
                        </div>
                        <div class="mt-4 flex flex-col gap-y-2">
                            <span class="text-xs uppercase tracking-wide text-secondary-900/70">
                                {step.eyebrow}
                            </span>
                            <h3 class="text-lg font-semibold tracking-tight text-secondary">
                                {step.title}
                            </h3>
                            <p class="text-sm text-secondary-900 leading-relaxed">
                                {step.description}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>

        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
            {
                techSpecs.map((spec) => (
                    <div class="flex items-center justify-center rounded-xl border border-quaternary-200 px-4 py-3">
                        <div class="inline-flex items-center gap-3">
                            <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-secondary" />
                            <span class="text-sm text-secondary-900">
                                <strong class="text-secondary">
                                    {spec.label}:{" "}
                                </strong>
                                {spec.value}
                            </span>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
