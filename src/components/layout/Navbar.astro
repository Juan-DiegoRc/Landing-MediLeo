---
import Logo from "../../assets/images/file.svg";
---
<header class="sticky top-0 z-10 border-b border-gray-200 bg-primary/80 backdrop-blur-md">
    <div class="mx-auto flex min-h-14 max-w-7xl flex-wrap items-center justify-between gap-2 px-4 py-2 sm:px-6 lg:px-8">
        <Logo width={140} class="w-32 sm:w-36 md:w-40" />
        <nav class="flex flex-wrap items-center justify-end gap-2 text-sm font-medium sm:gap-3 sm:text-base lg:gap-4 lg:text-lg text-secondary">
            <a href="#problem" class="transition-colors hover:text-secondary-900">Problema</a>
            <a href="#solution" class="transition-colors hover:text-secondary-900">Solución</a>
            <a href="#how-it-works" class="transition-colors hover:text-secondary-900">Como Funciona</a>
            <a href="#impact" class="transition-colors hover:text-secondary-900">Impacto</a>
            <a href="#team" class="transition-colors hover:text-secondary-900">Nosotros</a>
        </nav>
    </div>
</header>
