---
const producto = [
  { label: "Problema", href: "#problem" },
  { label: "Solución", href: "#solution" },
  { label: "Cómo funciona", href: "#how-it-works" },
  { label: "Impacto", href: "#impact" },
];

const proyecto = [
  { label: "Nosotros", href: "#nosotros" },
  { label: "Contacto", href: "mailto:contacto@medileo.com" },
  {label: "Redes", href: "https://www.instagram.com/medileo/"},
];

const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 px-6 pt-16 pb-8">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr] gap-10">
      <!-- Marca -->
      <div>
        <span class="text-lg font-bold text-gray-900">MediLEO</span>
        <p class="mt-3 text-sm text-gray-500 max-w-xs leading-relaxed">
          Medición inteligente de energía para hogares de la Costa Caribe
          colombiana, en tiempo real y sin instalaciones complejas.
        </p>
      </div>

      <!-- Columna Producto -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900 mb-3">Producto</h4>
        <ul class="space-y-2">
          {producto.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna Proyecto -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900 mb-3">Proyecto</h4>
        <ul class="space-y-2">
          {proyecto.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Línea inferior -->
    <div class="mt-12 pt-6 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <p>&copy; {year} MediLEO. Todos los derechos reservados.</p>
      <span class="inline-flex items-center gap-2 rounded-full border border-gray-200 px-3 py-1 text-xs text-gray-500">
        <span class="h-1.5 w-1.5 rounded-full bg-gray-900"></span>
        Hecho en Barranquilla, Colombia
      </span>
    </div>
  </div>
</footer>