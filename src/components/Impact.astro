---
const stats = [
  {
    value: "~15%",
    label:
      "Reducción de consumo estimada en hogares que monitorean su energía a diario, según estudios de medición inteligente residencial",
  },
  {
    value: "$30k–$60k",
    label:
      "COP/mes que un hogar de estrato medio podría recuperar ajustando hábitos de uso del AC y electrodomésticos",
  },
  {
    value: "<5 min",
    label:
      "Tiempo diario que toma revisar la app y detectar un consumo anómalo antes de que llegue la factura",
  },
];

const cards = [
  {
    title: "Ahorro económico directo",
    description:
      "Cada kWh evitado se refleja en la factura del mismo mes. Las alertas de consumo anómalo permiten actuar antes de que un equipo dañado o mal usado dispare el gasto.",
    badge: "Hasta 100 kWh/mes recuperables por hogar",
    icon: "trending-down",
  },
  {
    title: "Menor huella de carbono",
    description:
      "Menos energía desperdiciada significa menor demanda sobre la red y, en consecuencia, menores emisiones asociadas a la generación que abastece a la Costa Caribe.",
    badge: "Cada kWh ahorrado es CO₂ que no se emite",
    icon: "leaf",
  },
  {
    title: "Decisiones basadas en datos, no en intuición",
    description:
      "En vez de adivinar qué electrodoméstico consume más, el hogar tiene gráficas por hora y por día que muestran exactamente dónde se concentra el gasto.",
    badge: "Datos minuto a minuto, no solo la factura mensual",
    icon: "activity",
  },
  {
    title: "Equidad energética para la Costa",
    description:
      "Las regiones que pagan las tarifas más altas del país son las que menos herramientas tienen para entender su consumo. MediLEO lleva esa visibilidad donde más se necesita.",
    badge: "Visibilidad accesible, sin instalaciones complejas",
    icon: "scale",
  },
];

// SVGs inline estilo lucide (stroke, sin relleno) para no depender de paquetes externos
const icons: Record<string, string> = {
  "trending-down": `<polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/>`,
  leaf: `<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>`,
  activity: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  scale: `<path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>`,
};
---

<section id="impacto" class="px-6 py-24 max-w-6xl mx-auto">
  <!-- Eyebrow badge -->
  <div class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-1.5 text-sm text-gray-600 mb-6">
    <span class="h-1.5 w-1.5 rounded-full bg-gray-900"></span>
    Resultados esperados · Hogares con visibilidad en tiempo real
  </div>

  <!-- Heading -->
  <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight max-w-3xl">
    Ver tu consumo cambia cómo lo usas
  </h2>
  <p class="mt-4 text-gray-600 max-w-2xl text-lg">
    Cuando una familia puede ver en tiempo real cuánto está gastando, empieza
    a tomar decisiones distintas. Ese cambio de comportamiento es el
    verdadero impacto de MediLEO.
  </p>

  <!-- Stats row -->
  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    {stats.map((stat) => (
      <div class="rounded-2xl border border-gray-200 p-6">
        <div class="text-3xl font-bold text-gray-900">{stat.value}</div>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">{stat.label}</p>
      </div>
    ))}
  </div>

  <!-- Grid 2x2 de dimensiones de impacto -->
  <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
    {cards.map((card) => (
      <div class="rounded-2xl border border-gray-200 p-6">
        <div class="flex h-9 w-9 items-center justify-center rounded-full bg-gray-100 text-gray-700 mb-4">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            set:html={icons[card.icon]}
          />
        </div>
        <h3 class="font-semibold text-gray-900">{card.title}</h3>
        <p class="mt-2 text-sm text-gray-600 leading-relaxed">
          {card.description}
        </p>
        <span class="mt-4 inline-block rounded-full bg-gray-100 px-3 py-1 text-xs text-gray-600">
          {card.badge}
        </span>
      </div>
    ))}
  </div>
</section>