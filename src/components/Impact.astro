---
import EyebrowBadge from "../components/common/EyebrowBadge.astro";
import economico from "../assets/images/economico.png";
import social from "../assets/images/Social.png";
import ambiental from "../assets/images/ambiental.png";
import { ChevronLeft, ChevronRight } from "@lucide/astro";

const slides = [
  {
    tag: "01 · Económico",
    title: "Ahorro real en cada factura",
    description:
      "Con visibilidad en tiempo real, las familias identifican exactamente qué dispositivo está disparando su consumo y pueden actuar antes de que llegue la factura. Menos desperdicio, menos gasto.",
    detail:
      "Un hogar de estrato medio en Barranquilla puede recuperar entre $30k y $60k COP al mes ajustando hábitos de uso del aire acondicionado y electrodomésticos ineficientes.",
    image: economico,
    color: "bg-quaternary-100",
    textColor: "text-secondary",
    tagColor: "bg-quaternary-100 text-secondary",
  },
  {
    tag: "02 · Social",
    title: "Datos para todos, no solo para los que saben",
    description:
      "MediLEO traduce números técnicos en información clara y accionable. Cualquier hogar de la Costa puede entender su consumo sin necesidad de conocimientos de ingeniería.",
    detail:
      "Las regiones que pagan las tarifas más altas del país son las que menos herramientas tienen para entender su consumo. MediLEO cierra esa brecha con tecnología accesible.",
    image: social,
    color: "bg-secondary",
    textColor: "text-primary",
    tagColor: "bg-quaternary-100 text-secondary",
  },
  {
    tag: "03 · Ambiental",
    title: "Menos desperdicio, menos emisiones",
    description:
      "Cada kWh que un hogar deja de desperdiciar es energía que la red no tuvo que generar. A escala, miles de hogares con visibilidad reducen la demanda total y las emisiones asociadas.",
    detail:
      "No se trata solo de ahorrar dinero: se trata de consumir con conciencia. MediLEO convierte la medición inteligente en un hábito colectivo de bajo impacto ambiental.",
    image: ambiental,
    color: "bg-secondary-900",
    textColor: "text-primary",
    tagColor: "bg-quaternary-100 text-secondary",
  },
];
---

<section id="impact" class="px-6 py-24 bg-[#1A1100]">
  <div class="mx-auto flex w-full max-w-5xl flex-col">

    <EyebrowBadge label="Impacto · Económico · Social ·Ambiental" />

    <h2 class="text-4xl md:text-5xl font-bold text-primary leading-tight max-w-3xl font-primary">
      Un solo sistema, tres tipos de impacto
    </h2>
    <p class="mt-4 text-primary/80 max-w-2xl text-lg font-secondary">
      MediLEO no solo mide energía. Genera valor en tres dimensiones que se
      refuerzan entre sí: ahorro económico, equidad de información y
      cuidado ambiental.
    </p>

    <!-- Carrusel -->
    <div class="mt-12 relative" id="carousel">
      <!-- Slides -->
      <div class="overflow-hidden rounded-3xl">
        {slides.map((slide, i) => (
          <div
            class={`carousel-slide ${i === 0 ? "block" : "hidden"} grid grid-cols-1 md:grid-cols-2 min-h-105 rounded-3xl overflow-hidden`}
            data-index={i}
          >
            <!-- Panel de color / imagen -->
            <div class={`${slide.color} flex items-center justify-center p-0 order-last md:order-first min-h-70 md:min-h-full`}>
              <img
                src={slide.image.src}
                alt={slide.title}
                class="w-full h-full object-cover"
              />
            </div>

            <!-- Contenido -->
            <div class="bg-primary flex flex-col justify-center p-8 md:p-12">
              <span class={`self-start rounded-full px-3 py-1 text-xs font-semibold font-secondary ${slide.tagColor} mb-5`}>
                {slide.tag}
              </span>
              <h3 class="text-2xl md:text-3xl font-bold text-secondary leading-snug font-primary">
                {slide.title}
              </h3>
              <p class="mt-4 text-secondary-900/70 leading-relaxed font-secondary">
                {slide.description}
              </p>
              <p class="mt-4 text-sm text-secondary-900/60 leading-relaxed border-l-2 border-gray-200 pl-4 font-secondary">
                {slide.detail}
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- Controles -->
      <div class="mt-6 flex items-center justify-between">
        <!-- Dots -->
        <div class="flex gap-2" id="carousel-dots">
          {slides.map((_, i) => (
            <button
              class={`carousel-dot h-2 rounded-full transition-all duration-300 ${i === 0 ? "w-6 bg-quaternary" : "w-2 bg-quaternary-200"}`}
              data-dot={i}
              aria-label={`Ir al slide ${i + 1}`}
            />
          ))}
        </div>

        <!-- Flechas -->
        <div class="flex gap-2">
          <button
            id="carousel-prev"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-secondary hover:opacity-90 transition-opacity"
            aria-label="Anterior"
          >
            <ChevronLeft/>
          </button>
          <button
            id="carousel-next"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-secondary hover:opacity-90 transition-opacity"
            aria-label="Siguiente"
          >
            <ChevronRight/>
          </button>
        </div>
      </div>
    </div>
  </div>

</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>(".carousel-slide");
  const dots   = document.querySelectorAll<HTMLElement>(".carousel-dot");
  let current  = 0;

  function goTo(index: number) {
    slides[current].classList.add("hidden");
    slides[current].classList.remove("block");
    dots[current].classList.remove("w-6", "bg-secondary");
    dots[current].classList.add("w-2", "bg-quaternary-200");

    // Mostrar nuevo
    current = (index + slides.length) % slides.length;
    slides[current].classList.remove("hidden");
    slides[current].classList.add("block");
    dots[current].classList.remove("w-2", "bg-quaternary-200");
    dots[current].classList.add("w-6", "bg-quaternary");
  }

  document.getElementById("carousel-next")?.addEventListener("click", () => goTo(current + 1));
  document.getElementById("carousel-prev")?.addEventListener("click", () => goTo(current - 1));
  dots.forEach((dot, i) => dot.addEventListener("click", () => goTo(i)));
</script>