---
// src/components/Impacto.astro
// Carrusel de triple impacto — vanilla JS, sin React ni dependencias extra.
// Las "imágenes" son placeholders de color; reemplaza el <div class="slide-img">
// por <img src="..." /> cuando tengas los assets reales de Figma.

const slides = [
  {
    tag: "01 · Económico",
    title: "Ahorro real en cada factura",
    description:
      "Con visibilidad en tiempo real, las familias identifican exactamente qué dispositivo está disparando su consumo y pueden actuar antes de que llegue la factura. Menos desperdicio, menos gasto.",
    detail:
      "Un hogar de estrato medio en Barranquilla puede recuperar entre $30k y $60k COP al mes ajustando hábitos de uso del aire acondicionado y electrodomésticos ineficientes.",
    color: "bg-quaternary-100",
    textColor: "text-secondary",
    tagColor: "bg-quaternary-100 text-secondary",
  },
  {
    tag: "02 · Social",
    title: "Datos para todos, no solo para los que saben",
    description:
      "MediLEO traduce números técnicos en información clara y accionable. Cualquier hogar de la Costa puede entender su consumo sin necesidad de conocimientos de ingeniería.",
    detail:
      "Las regiones que pagan las tarifas más altas del país son las que menos herramientas tienen para entender su consumo. MediLEO cierra esa brecha con tecnología accesible.",
    color: "bg-secondary",
    textColor: "text-primary",
    tagColor: "bg-primary text-secondary",
  },
  {
    tag: "03 · Ambiental",
    title: "Menos desperdicio, menos emisiones",
    description:
      "Cada kWh que un hogar deja de desperdiciar es energía que la red no tuvo que generar. A escala, miles de hogares con visibilidad reducen la demanda total y las emisiones asociadas.",
    detail:
      "No se trata solo de ahorrar dinero: se trata de consumir con conciencia. MediLEO convierte la medición inteligente en un hábito colectivo de bajo impacto ambiental.",
    color: "bg-secondary-900",
    textColor: "text-primary",
    tagColor: "bg-primary text-secondary",
  },
];
---

<section id="impact" class="px-6 py-24 max-w-6xl mx-auto">
  <!-- Eyebrow -->
  <div class="inline-flex items-center gap-2 rounded-full border border-quaternary-200 bg-primary px-4 py-1.5 text-sm text-secondary-900/70 mb-6">
    <span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>
    Triple impacto · Económico · Social · Ambiental
  </div>

  <h2 class="text-4xl md:text-5xl font-bold text-secondary leading-tight max-w-3xl">
    Un solo sistema, tres tipos de impacto
  </h2>
  <p class="mt-4 text-secondary-900/70 max-w-2xl text-lg">
    MediLEO no solo mide energía. Genera valor en tres dimensiones que se
    refuerzan entre sí: ahorro económico, equidad de información y
    cuidado ambiental.
  </p>

  <!-- Carrusel -->
  <div class="mt-12 relative" id="carousel">
    <!-- Slides -->
    <div class="overflow-hidden rounded-3xl">
      {slides.map((slide, i) => (
        <div
          class={'carousel-slide ${i === 0 ? "block" : "hidden"} grid grid-cols-1 md:grid-cols-2 min-h-[420px] rounded-3xl overflow-hidden'}
          data-index={i}
        >
          <!-- Panel de color / imagen -->
          <div class={'${slide.color} flex items-center justify-center p-12 order-last md:order-first'}>
            <!--
              <img src="/assets/impacto-economico.webp" alt="..." class="w-full max-w-xs object-contain" />
            -->
            <div class="flex flex-col items-center gap-4 opacity-90">
              <div class={'text-7xl font-black ${slide.textColor} opacity-20 select-none leading-none'}>
                {i + 1}
              </div>
              <div class={'w-24 h-1 rounded-full ${slide.textColor} opacity-30'}></div>
              <p class={'text-sm font-semibold tracking-widest uppercase ${slide.textColor} opacity-60'}>
                MediLEO
              </p>
            </div>
          </div>

          <!-- Contenido -->
          <div class="bg-white flex flex-col justify-center p-8 md:p-12">
            <span class={'self-start rounded-full px-3 py-1 text-xs font-semibold ${slide.tagColor} mb-5'}>
              {slide.tag}
            </span>
            <h3 class="text-2xl md:text-3xl font-bold text-secondary leading-snug">
              {slide.title}
            </h3>
            <p class="mt-4 text-secondary-900/70 leading-relaxed">
              {slide.description}
            </p>
            <p class="mt-4 text-sm text-secondary-900/60 leading-relaxed border-l-2 border-quaternary-200 pl-4">
              {slide.detail}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Controles -->
    <div class="mt-6 flex items-center justify-between">
      <!-- Dots -->
      <div class="flex gap-2" id="carousel-dots">
        {slides.map((_, i) => (
          <button
            class={'carousel-dot h-2 rounded-full transition-all duration-300 ${i === 0 ? "w-6 bg-secondary" : "w-2 bg-quaternary-200"}'}
            data-dot={i}
            aria-label={`Ir al slide ${i + 1}`}
          />
        ))}
      </div>

      <!-- Flechas -->
      <div class="flex gap-2">
        <button
          id="carousel-prev"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-quaternary-200 text-secondary-900/60 hover:border-secondary hover:text-secondary transition-colors"
          aria-label="Anterior"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" class="h-4 w-4">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <button
          id="carousel-next"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-secondary text-primary hover:opacity-90 transition-opacity"
          aria-label="Siguiente"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" class="h-4 w-4">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>(".carousel-slide");
  const dots   = document.querySelectorAll<HTMLElement>(".carousel-dot");
  let current  = 0;

  function goTo(index: number) {
    slides[current].classList.add("hidden");
    slides[current].classList.remove("block");
    dots[current].classList.remove("w-6", "bg-secondary");
    dots[current].classList.add("w-2", "bg-quaternary-200");

    // Mostrar nuevo
    current = (index + slides.length) % slides.length;
    slides[current].classList.remove("hidden");
    slides[current].classList.add("block");
    dots[current].classList.remove("w-2", "bg-quaternary-200");
    dots[current].classList.add("w-6", "bg-secondary");
  }

  document.getElementById("carousel-next")?.addEventListener("click", () => goTo(current + 1));
  document.getElementById("carousel-prev")?.addEventListener("click", () => goTo(current - 1));
  dots.forEach((dot, i) => dot.addEventListener("click", () => goTo(i)));
</script>